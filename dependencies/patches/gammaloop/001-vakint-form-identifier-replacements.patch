+pub fn multi_form_identifier_replace(text: String, repls: &HashMap<String, String>) -> String {
+    let mut patterns: Vec<String> = repls.keys().cloned().collect();
+    patterns.sort_unstable_by_key(|s| std::cmp::Reverse(s.len()));
+
+    let mut out = String::with_capacity(text.len());
+    let mut position = 0;
+    while position < text.len() {
+        let matched = patterns.iter().find(|pattern| {
+            text[position..].starts_with(pattern.as_str())
+                && form_identifier_boundary(&text, position)
+                && form_identifier_boundary(&text, position + pattern.len())
+        });
+        if let Some(pattern) = matched {
+            out.push_str(&repls[pattern]);
+            position += pattern.len();
+            continue;
+        }
+        let next = text[position..].chars().next().unwrap();
+        out.push(next);
+        position += next.len_utf8();
+    }
+    out
+}
+
+fn form_identifier_boundary(text: &str, position: usize) -> bool {
+    if position == 0 || position == text.len() {
+        return true;
+    }
+    let before = text[..position].chars().next_back().unwrap();
+    let after = text[position..].chars().next().unwrap();
+    !is_form_identifier_char(before) || !is_form_identifier_char(after)
+}
+
+fn is_form_identifier_char(c: char) -> bool {
+    c.is_ascii_alphanumeric() || c == '_'
+}
